{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SchoolSoft Calendar Helper",
  "version": "0.1.0",
  "identifier": "com.villeolof1.schoolsoftcalendarhelper",
  "build": {
    "beforeDevCommand": "npm run start:desktop",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "SchoolSoft Calendar Helper",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Productivity"
  }
}
