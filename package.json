{
  "name": "schoolsoft-calendar-helper",
  "version": "0.1.0",
  "type": "module",
  "description": "Unofficial local-first SchoolSoft calendar helper. Data stays on the user's computer.",
  "scripts": {
    "install-browsers": "npx playwright install chromium",
    "login": "node scripts/login.js",
    "extract": "node scripts/extract.js",
    "manual-capture": "node scripts/manual-capture.js",
    "start": "node server.js",
    "start:auto": "node server.js",
    "start:no-auto": "node server.js --no-auto",
    "start:desktop": "node scripts/desktop-sidecar.js",
    "check": "node scripts/check.js",
    "build:sidecar": "node scripts/build-sidecar.js",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build"
  },
  "dependencies": {
    "playwright": "^1.56.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@yao-pkg/pkg": "^6.19.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/villeolof1/schoolsoft-calendar-helper.git"
  },
  "bugs": {
    "url": "https://github.com/villeolof1/schoolsoft-calendar-helper/issues"
  },
  "homepage": "https://villeolof1.github.io/schoolsoft-calendar-helper/",
  "pkg": {
    "scripts": [
      "server.js",
      "scripts/**/*.js"
    ],
    "assets": [
      "public/**/*",
      "schoolsoft.config.example.json",
      "node_modules/playwright/**/*",
      "node_modules/playwright-core/**/*"
    ]
  }
}
